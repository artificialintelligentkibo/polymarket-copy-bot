# Wallet to monitor
TARGET_WALLET=0xTARGET_WALLET_TO_COPY

# Execution auth
# AUTH_MODE defaults to EOA when omitted for backward compatibility.
AUTH_MODE=PROXY

# SIGNER_PRIVATE_KEY is preferred; PRIVATE_KEY and EXECUTION_WALLET_PRIVATE_KEY remain supported.
SIGNER_PRIVATE_KEY=0xYOUR_SIGNER_PRIVATE_KEY
PRIVATE_KEY=
EXECUTION_WALLET_PRIVATE_KEY=

# EOA mode:
# - SIGNATURE_TYPE defaults to 0
# - FUNDER_ADDRESS is ignored because signer=funder
#
# PROXY mode:
# - SIGNATURE_TYPE must be 1 (POLY_PROXY) or 2 (GNOSIS_SAFE)
# - FUNDER_ADDRESS must be the Polymarket proxy/funder wallet that holds USDC.e and approvals
SIGNATURE_TYPE=1
FUNDER_ADDRESS=

# Polygon RPC
RPC_URL=https://polygon.drpc.org

# Optional geo token (if provided by Polymarket for your account/region)
POLYMARKET_GEO_TOKEN=

# Trading
COPY_SELLS=false
POSITION_MULTIPLIER=0.05
MAX_TRADE_SIZE=5
MIN_TRADE_SIZE=1.10
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=GTC
ORDER_TYPE_FALLBACK=GTC

# Auto settlement
# AUTO_REDEEM=true  # працює тільки з EOA wallet. З PROXY redeem часто потребує ручного підпису
# AUTO_SELL_THRESHOLD=0.88   # рекомендовано для thin 5-min markets
AUTO_REDEEM=true
AUTO_SELL_THRESHOLD=0.88
REDEEM_INTERVAL_MS=30000

# Run until first SELL is copied, then exit (for validation)
EXIT_AFTER_FIRST_SELL_COPY=false

# Risk (0 disables the cap)
MAX_SESSION_NOTIONAL=0
MAX_PER_MARKET_NOTIONAL=0

# Monitoring
USE_WEBSOCKET=true
USE_USER_CHANNEL=false
POLL_INTERVAL=2000
WS_ASSET_IDS=
WS_MARKET_IDS=

# Optional gas floor overrides for Polygon approval/order txs
MIN_PRIORITY_FEE_GWEI=30
MIN_MAX_FEE_GWEI=60
